{
  "name": "bonafied",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "deploy:preflight": "node scripts/deploy-preflight.mjs",
    "worker:ingest": "node scripts/ingest-worker.mjs",
    "compose:up": "docker compose up -d --build",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f --tail 120 app worker postgres redis",
    "smoke": "node scripts/smoke-check.mjs",
    "first": "npm run compose:up && npm run smoke",
    "legacy:dev": "vite",
    "legacy:server": "node server/index.mjs",
    "legacy:dev:full": "concurrently -k \"npm run legacy:server\" \"npm run legacy:dev\""
  },
  "dependencies": {
    "@google/genai": "^1.41.0",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "framer-motion": "^12.23.24",
    "gsap": "^3.14.2",
    "helmet": "^8.1.0",
    "lucide-react": "^0.563.0",
    "next": "^15.3.3",
    "nodemailer": "^8.0.1",
    "pg": "^8.16.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "redis": "^5.8.2",
    "rss-parser": "^3.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "typescript": "~5.8.2"
  }
}
