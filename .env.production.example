NEXT_PUBLIC_APP_URL=https://your-domain.com
APP_URL=https://your-domain.com

# Access control
AR_ALLOWED_EMAILS=
AR_SELF_SIGNUP=true
AR_DEFAULT_ADMIN_EMAILS=you@company.com

# Core persistence and cache (hosted providers)
DATABASE_URL=postgres://username:password@host:5432/database?sslmode=require
DATABASE_SSL=require
REDIS_URL=redis://default:password@host:6379

# Scheduled ingestion auth
INGEST_CRON_SECRET=replace-with-long-random-secret
CRON_SECRET=replace-with-long-random-secret
INGEST_INTERVAL_MINUTES=15
BONAFIED_MIN_FEED_CREDIBILITY=0.72
BONAFIED_MIN_PROVIDER_CREDIBILITY=0.78

# SMTP for password reset emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Server-side AI keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional ingestion providers
NEWSAPI_KEY=
GNEWS_API_KEY=
