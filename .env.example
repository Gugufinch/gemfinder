NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=http://127.0.0.1:3000
AR_ALLOWED_EMAILS=
AR_SELF_SIGNUP=true
AR_DEFAULT_ADMIN_EMAILS=

# Core persistence + cache
DATABASE_URL=postgres://bonafied:bonafied@127.0.0.1:5432/bonafied
DATABASE_SSL=
REDIS_URL=redis://127.0.0.1:6379

# Scheduled ingestion auth
INGEST_CRON_SECRET=change-me
# For Vercel Cron, set CRON_SECRET to the same value in production.
CRON_SECRET=change-me
INGEST_INTERVAL_MINUTES=15
BONAFIED_MIN_FEED_CREDIBILITY=0.72
BONAFIED_MIN_PROVIDER_CREDIBILITY=0.78

# Optional SMTP for AR password reset emails
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional server-side AI keys for /api/ai/*
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional ingestion API providers (used in addition to RSS)
NEWSAPI_KEY=
GNEWS_API_KEY=
